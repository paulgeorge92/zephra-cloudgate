  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",

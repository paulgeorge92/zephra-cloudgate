{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "sourceMap": true,
    "outDir": "./dist-server",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "src/*": ["./server/backend/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "types": ["node"],
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "dist-server", "**/*.spec.ts", "server/backend/main.ts"]
}
